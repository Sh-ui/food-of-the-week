---
// Cheffy.astro -- corner mascot + state-machine host. STUB / SCAFFOLD.
// Full design contract: ../../CHEFFY-SYSTEM.md ; checklist: ../../TODOS.md (Phase 3-4).
//
// Progressive enhancement only: the site must work fully without this component.
// NOT yet mounted in Layout.astro -- wiring is the final build-out step so the
// branch keeps behaving exactly like master until Cheffy is real.
//
// Props let a page opt out (e.g. print views) and pick a corner.
import fs from 'fs';
import path from 'path';
import CheffyPanel from './CheffyPanel.astro';
import dialogue from '../data/cheffy-dialogue.json';
import { deriveWeekStart, extractCookingEvents, buildIcs, googleCalendarUrl }
  from '../utils/cheffyCalendar';

interface Props {
  /** Hide Cheffy entirely on this page (default: shown). */
  enabled?: boolean;
  /** Screen corner to dock in. */
  corner?: 'bottom-right' | 'bottom-left' | 'top-right' | 'top-left';
  /** Relative path (from project root) to this page's week Markdown source, for
   *  calendar-actions. Optional -- until a page threads it, the calendar island
   *  stays empty and generate-ics/-meal/open-google-calendar handlers no-op. */
  filename?: string;
}

const { enabled = true, corner = 'bottom-right', filename } = Astro.props;
const startNode = dialogue.start ?? 'root';

// Build-time calendar data island -- see notes/job_cheffy_calactions_plan.md.
// Runs in Node/SSR context (Buffer available), so it is safe to call buildIcs here.
// NEVER call buildIcs/extractCookingEvents/deriveWeekStart from client code.
let calendarIsland: {
  weekIcs: string;
  weekGoogleUrl: string | null;
  meals: Array<{ mealSlug: string; label: string; ics: string; googleUrl: string }>;
} = { weekIcs: '', weekGoogleUrl: null, meals: [] };

if (filename) {
  try {
    const md = fs.readFileSync(path.join(process.cwd(), filename), 'utf-8');
    const weekStart = deriveWeekStart(md, filename);
    if (weekStart) {
      const events = extractCookingEvents(md, weekStart);
      if (events.length) {
        calendarIsland.weekIcs = buildIcs(events);
        calendarIsland.weekGoogleUrl = googleCalendarUrl(events[0]);
        const bySlug = new Map<string, typeof events>();
        for (const ev of events) {
          const key = ev.mealSlug || 'cooking';
          (bySlug.get(key) ?? bySlug.set(key, []).get(key)!).push(ev);
        }
        calendarIsland.meals = [...bySlug.entries()].map(([mealSlug, evs]) => ({
          mealSlug,
          label: (evs[0].title.split(' -- ')[0] || mealSlug).trim(),
          ics: buildIcs(evs),
          googleUrl: googleCalendarUrl(evs[0]),
        }));
      }
    }
  } catch {
    // leave empty island -- never break the build
  }
}
---

{enabled && (
  <div
    id="cheffy"
    class="cheffy-root"
    data-corner={corner}
    data-state="idle"
    data-start-node={startNode}
    aria-live="polite"
  >
    <button type="button" class="cheffy-toggle" aria-expanded="false" aria-controls="cheffy-panel">
      <span class="sr-only">Open Cheffy</span>
      <svg class="cheffy-svg" viewBox="0 0 200 200" role="img" aria-hidden="true" focusable="false">
        <!-- hat: static, never swapped -->
        <path class="cheffy-hat" d="M60 90 q-30 -5 -28 -35 q0 -28 30 -28 q8 -22 38 -22 q30 0 38 22 q30 0 30 28 q2 30 -28 35 z"/>
        <rect class="cheffy-band" x="58" y="88" width="84" height="34" rx="8"/>

        <!-- EYES: one <g data-part="eyes"> containing one child per expression -->
        <g class="cheffy-eyes" data-part="eyes">
          <g data-expr="neutral">
            <circle class="eye" cx="86" cy="62" r="5"/>
            <circle class="eye" cx="114" cy="62" r="5"/>
          </g>
          <g data-expr="excited">
            <circle class="eye" cx="86" cy="60" r="6"/>
            <circle class="eye" cx="114" cy="60" r="6"/>
          </g>
          <g data-expr="thinking">
            <!-- half-lidded / looking-up eyes; no blink -->
            <path class="eye" d="M81 62 q5 -4 10 0" fill="none" stroke-width="3"/>
            <path class="eye" d="M109 62 q5 -4 10 0" fill="none" stroke-width="3"/>
          </g>
        </g>

        <!-- MOUTH: one <g data-part="mouth"> containing one child per mouth shape -->
        <g class="cheffy-mouth" data-part="mouth">
          <path data-mouth="neutral" d="M88 76 h24" fill="none" stroke-width="4" stroke-linecap="round"/>
          <path data-mouth="smile" d="M86 74 q14 12 28 0" fill="none" stroke-width="4" stroke-linecap="round"/>
          <circle data-mouth="surprised" cx="100" cy="78" r="5" fill="none" stroke-width="4"/>
        </g>

        <!-- notification dot: CSS-shown only in attention -->
        <circle class="cheffy-dot" data-part="notification-dot" cx="150" cy="30" r="10"/>
      </svg>
    </button>
    <CheffyPanel />
    <script type="application/json" id="cheffy-week-ics" is:inline
            set:html={JSON.stringify(calendarIsland)} />
  </div>
)}

<style>
  /* fills/strokes -- brand tokens */
  .cheffy-hat  { fill: var(--color-bg);        stroke: var(--color-primary); stroke-width: 4; stroke-linejoin: round; }
  .cheffy-band { fill: var(--color-secondary); stroke: var(--color-primary); stroke-width: 4; }
  .cheffy-eyes .eye,
  .cheffy-mouth [data-mouth] { fill: var(--color-primary); stroke: var(--color-primary); }
  .cheffy-dot  { fill: var(--color-accent); }

  /* --- expression swap: everything hidden, state re-shows exactly one --- */
  #cheffy [data-expr],
  #cheffy [data-mouth]  { display: none; }
  #cheffy .cheffy-dot   { display: none; }

  /* eyes per state */
  #cheffy[data-state="idle"]       [data-expr="neutral"],
  #cheffy[data-state="dialogue"]   [data-expr="neutral"],
  #cheffy[data-state="attention"]  [data-expr="excited"],
  #cheffy[data-state="processing"] [data-expr="thinking"] { display: block; }

  /* mouth per state (dialogue -> smile; attention -> surprised; idle/processing -> neutral) */
  #cheffy[data-state="idle"]       [data-mouth="neutral"],
  #cheffy[data-state="processing"] [data-mouth="neutral"],
  #cheffy[data-state="attention"]  [data-mouth="surprised"],
  #cheffy[data-state="dialogue"]   [data-mouth="smile"] { display: block; }

  /* notification dot only in attention */
  #cheffy[data-state="attention"] .cheffy-dot { display: block; }

  @keyframes cheffy-blink {
    0%, 92%, 100% { transform: scaleY(1); }
    95%           { transform: scaleY(0.1); }
  }
  @media (prefers-reduced-motion: no-preference) {
    #cheffy[data-state="idle"] [data-expr="neutral"] .eye {
      transform-box: fill-box;
      transform-origin: center;
      animation: cheffy-blink 4.5s ease-in-out infinite;
    }
  }

  /* per-node expression override, set by the CheffyPanel dialogue runtime (data-expr-override on #cheffy) */
  #cheffy[data-expr-override] [data-expr],
  #cheffy[data-expr-override] [data-mouth] { display: none; }

  #cheffy[data-expr-override="neutral"]  [data-expr="neutral"],
  #cheffy[data-expr-override="excited"]  [data-expr="excited"],
  #cheffy[data-expr-override="thinking"] [data-expr="thinking"] { display: block; }

  /* mouth mapping mirrors the state mapping (excited->smile, thinking/neutral->neutral) */
  #cheffy[data-expr-override="neutral"]  [data-mouth="neutral"],
  #cheffy[data-expr-override="thinking"] [data-mouth="neutral"],
  #cheffy[data-expr-override="excited"]  [data-mouth="smile"] { display: block; }
</style>

<script>
  import { slugifyWeekTitle, isNewWeek, markVisited, initialStateFor,
           type VisitedWeeks } from '../utils/cheffyState';

  const VISITED_KEY = 'visitedWeeks';   // GLOBAL key, object map -- NOT per-week

  function getWeekIdFromDocument(): string {
    const title = document.querySelector('h1')?.textContent || 'current-week';
    return slugifyWeekTitle(title);
  }
  function loadVisited(): VisitedWeeks {
    try { return JSON.parse(localStorage.getItem(VISITED_KEY) || '{}'); }
    catch { return {}; }
  }
  function saveVisited(v: VisitedWeeks): void {
    localStorage.setItem(VISITED_KEY, JSON.stringify(v));
  }

  function initCheffy(): void {
    const root = document.getElementById('cheffy');
    if (!root) return;                                   // absent on this page -> no-op
    const toggle = root.querySelector<HTMLButtonElement>('.cheffy-toggle');
    const panel  = document.getElementById('cheffy-panel');
    if (!toggle || !panel) return;

    const weekId = getWeekIdFromDocument();
    const visited = loadVisited();
    const isNew = isNewWeek(visited, weekId);

    // --- single source of truth for the active state ---
    function setState(s: 'idle' | 'attention' | 'dialogue' | 'processing') {
      root.setAttribute('data-state', s);
    }

    // first paint: new week -> attention(+dot), else idle
    setState(initialStateFor(isNew));

    // mark the week visited (clears attention path) + fall back to idle
    function visit() {
      if (isNewWeek(loadVisited(), weekId)) saveVisited(markVisited(loadVisited(), weekId));
    }

    // --- toggle / open-close wiring (panel VISIBILITY only) ---
    function openPanel() {
      panel.hidden = false;
      toggle.setAttribute('aria-expanded', 'true');
      visit();
      setState('dialogue');
    }
    function closePanel() {
      panel.hidden = true;
      toggle.setAttribute('aria-expanded', 'false');
      visit();
      setState('idle');
    }
    toggle.addEventListener('click', () => {
      (toggle.getAttribute('aria-expanded') === 'true') ? closePanel() : openPanel();
    });

    // processing: documented NO-OP hook for later parts (calendar-actions, notifications).
    // They will call setState('processing') / setState('idle') around async work.
    // Part 2 never triggers it. Expose the hook so later parts don't reach into internals:
    (root as any).cheffySetState = setState;   // minimal seam; refine in a later part
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCheffy);
  } else {
    initCheffy();
  }
</script>

<script>
  // Registers the calendar-actions handlers (generate-ics, generate-ics-meal,
  // open-google-calendar) against the part-3 action-dispatch registry. Bundled
  // (not is:inline) so the ES import resolves; module-load side effect only.
  import '../utils/cheffyCalendarActions';
</script>

<script>
  // Registers the notifications handler (trigger-permission) against the
  // part-3 action-dispatch registry. Bundled (not is:inline) so the ES import
  // resolves; module-load side effect only.
  import '../utils/cheffyNotifications';
</script>
