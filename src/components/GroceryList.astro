---
import type { ListCategory } from '../utils/weekParser';

interface Props {
  categories: ListCategory[];
  hasLunchItems?: boolean;
  lunchDefaultOn?: boolean;
}

const { categories, hasLunchItems = false, lunchDefaultOn = true } = Astro.props;

const hasCheckedItems = categories.some((category) =>
  category.items.some((item) => item.globallyChecked)
);
---

<div id="grocery-list" class="slug-anchor" aria-hidden="true"></div>
<div
  id="print-section-grocery-list"
  class="print-section bg-bg border border-solid border-border rounded-lg p-lg mb-xl w-full"
  data-section-type="grocery"
>
  <div class="flex justify-between items-center gap-md flex-wrap mb-lg">
    <h2>Grocery List</h2>
    <div class="flex items-center gap-md flex-wrap">
      {hasCheckedItems && (
        <label class="lunch-toggle flex items-center gap-sm cursor-pointer" title="Hide items already checked off">
          <span class="lunch-toggle-label checked-toggle-label">✓ Hide checked</span>
          <span class="lunch-switch">
            <input type="checkbox" id="checked-grocery-toggle" checked />
            <span class="lunch-slider checked-slider"></span>
          </span>
        </label>
      )}
      {hasLunchItems && (
        <label class="lunch-toggle flex items-center gap-sm cursor-pointer" title="Fold mom's lunch groceries into the list">
          <span class="lunch-toggle-label">🥪 Lunch</span>
          <span class="lunch-switch">
            <input type="checkbox" id="lunch-grocery-toggle" checked={lunchDefaultOn} />
            <span class="lunch-slider"></span>
          </span>
        </label>
      )}
    </div>
  </div>

  <div class={`grid gap-lg ${hasCheckedItems ? 'hide-checked-items' : ''}`} id="grocery-categories">
    {categories.map((category) => (
      <div class="grocery-category bg-bg-alt p-md rounded-md mobile:p-lg">
        <h3 class="mt-0 mb-md text-primary text-[1.4rem] mobile:text-[1.75rem] mobile:mb-md">{category.name}</h3>
        <ul class="grocery-items flex flex-col gap-sm">
          {category.items.map((item, index) => (
            <li class={`flex items-center grocery-item ${item.globallyChecked ? 'globally-checked' : ''} ${item.isLunch ? 'lunch-item' : ''} ${item.coversLunch ? 'covers-lunch' : ''}`}>
              <label class="flex items-center cursor-pointer w-full p-[calc(var(--spacing-xs)+2px)] rounded transition-colors hover:bg-[rgba(44,95,45,0.05)] text-[1.1rem] leading-relaxed mobile:p-sm mobile:text-[1.3rem]">
        <input
          type="checkbox"
          class="grocery-checkbox local-checkbox"
          data-category={category.name}
          data-index={index}
          data-item={item.text}
          data-globally-checked={item.globallyChecked ? 'true' : 'false'}
        />
                <span class="flex-1 item-text mobile:text-[1.3rem] mobile:leading-extra-loose">{item.text}</span>
              </label>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</div>

<script>
  // Store checked items in localStorage with week-specific key
  function getStorageKey(): string {
    // Get week title from page to create unique key
    const weekElement = document.querySelector('h1');
    const weekTitle = weekElement?.textContent || 'current-week';
    return `grocery-list-${weekTitle.toLowerCase().replace(/\s+/g, '-')}`;
  }

  function loadCheckedItems(): Set<string> {
    const key = getStorageKey();
    const stored = localStorage.getItem(key);
    return stored ? new Set(JSON.parse(stored)) : new Set();
  }

  function saveCheckedItems(checked: Set<string>): void {
    const key = getStorageKey();
    localStorage.setItem(key, JSON.stringify([...checked]));
  }

  function getItemKey(checkbox: HTMLInputElement): string {
    const category = checkbox.dataset.category || '';
    const index = checkbox.dataset.index || '';
    const item = checkbox.dataset.item || '';
    return `${category}::${index}::${item}`;
  }

  // Initialize checkboxes from storage
  function initializeCheckboxes(): void {
    const checked = loadCheckedItems();
    const checkboxes = document.querySelectorAll<HTMLInputElement>('.grocery-checkbox');
    
    checkboxes.forEach((checkbox) => {
      const itemKey = getItemKey(checkbox);
      const parentItem = checkbox.closest('.grocery-item');

      if (checked.has(itemKey)) {
        checkbox.checked = true;
        parentItem?.classList.add('locally-checked');
      } else {
        checkbox.checked = false;
      }

      checkbox.addEventListener('change', () => {
        const currentChecked = loadCheckedItems();
        if (checkbox.checked) {
          currentChecked.add(itemKey);
          parentItem?.classList.add('locally-checked');
        } else {
          currentChecked.delete(itemKey);
          parentItem?.classList.remove('locally-checked');
        }
        saveCheckedItems(currentChecked);
      });
    });
  }

  // Fold/unfold lunch items and hide checked-off items in place (per-row, not a
  // separate section). A category whose every item is hidden by an active filter
  // collapses along with them. Reads current filter state from the container so
  // both toggles share one visibility pass.
  function refreshCategoryVisibility(): void {
    const container = document.getElementById('grocery-categories');
    if (!container) return;
    const hideLunch = container.classList.contains('hide-lunch-items');
    const hideChecked = container.classList.contains('hide-checked-items');

    document.querySelectorAll<HTMLElement>('.grocery-category').forEach((category) => {
      const items = Array.from(category.querySelectorAll('.grocery-item'));
      const hasVisibleItem = items.some((item) => {
        const hiddenByLunch = hideLunch && item.classList.contains('lunch-item');
        const hiddenByChecked = hideChecked && item.classList.contains('globally-checked');
        return !hiddenByLunch && !hiddenByChecked;
      });
      category.style.display = hasVisibleItem ? '' : 'none';
    });
  }

  function initializeLunchToggle(): void {
    const TOGGLE_KEY = 'lunch-grocery-in-list-enabled';
    const toggle = document.getElementById('lunch-grocery-toggle') as HTMLInputElement | null;
    const container = document.getElementById('grocery-categories');
    if (!toggle || !container) return;

    const stored = localStorage.getItem(TOGGLE_KEY);
    const isOn = stored === null ? toggle.checked : stored === 'true';
    toggle.checked = isOn;
    container.classList.toggle('hide-lunch-items', !isOn);
    refreshCategoryVisibility();

    toggle.addEventListener('change', () => {
      container.classList.toggle('hide-lunch-items', !toggle.checked);
      localStorage.setItem(TOGGLE_KEY, String(toggle.checked));
      refreshCategoryVisibility();
    });
  }

  // Toggle to hide items already checked off in the source ("globally checked",
  // rendered grayed out). On by default, so shopping lists start uncluttered.
  function initializeCheckedToggle(): void {
    const TOGGLE_KEY = 'grocery-hide-checked-enabled';
    const toggle = document.getElementById('checked-grocery-toggle') as HTMLInputElement | null;
    const container = document.getElementById('grocery-categories');
    if (!toggle || !container) return;

    const stored = localStorage.getItem(TOGGLE_KEY);
    // Default ON (hide checked) when there's no stored preference.
    const isOn = stored === null ? true : stored === 'true';
    toggle.checked = isOn;
    container.classList.toggle('hide-checked-items', isOn);
    refreshCategoryVisibility();

    toggle.addEventListener('change', () => {
      container.classList.toggle('hide-checked-items', toggle.checked);
      localStorage.setItem(TOGGLE_KEY, String(toggle.checked));
      refreshCategoryVisibility();
    });
  }

  // Initialize on page load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      initializeCheckboxes();
      initializeLunchToggle();
      initializeCheckedToggle();
    });
  } else {
    initializeCheckboxes();
    initializeLunchToggle();
    initializeCheckedToggle();
  }
</script>

<style>
  /* Semantic state classes - keep for functionality */
  .grocery-item.locally-checked .item-text {
    text-decoration: line-through;
    color: var(--color-text-light);
  }

  .grocery-item.globally-checked .item-text {
    color: var(--color-text-muted, #9a9a91);
  }

  .local-checkbox {
    position: relative;
    -webkit-appearance: none;
    -moz-appearance: none;
    appearance: none;
    background: var(--color-bg);
    border: 2px solid var(--color-border);
    cursor: pointer;
  }

  .local-checkbox:checked {
    background: var(--color-primary);
    border-color: var(--color-primary);
  }

  .local-checkbox:before {
    content: '';
    position: absolute;
    inset: 2px;
    border: 2px solid transparent;
    border-radius: 50%;
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  .local-checkbox[data-globally-checked="true"]::before {
    border-color: var(--color-text-muted);
    opacity: 1;
  }

  .local-checkbox:checked::after {
    content: '✓';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    color: white;
    font-size: 0.85rem;
    font-weight: 600;
    line-height: 1;
  }

  .local-checkbox:checked[data-globally-checked="true"]::before {
    opacity: 0;
  }

  /* Lunch items folded into the list: same size/format, cooler color marks them apart */
  .grocery-item.lunch-item .item-text {
    color: var(--color-lunch);
  }

  .grocery-item.lunch-item .item-text::before {
    content: '';
    display: inline-block;
    width: 0.5em;
    height: 0.5em;
    margin-right: 0.5em;
    border-radius: 50%;
    background: var(--color-lunch-light);
    vertical-align: middle;
  }

  .grocery-item.lunch-item.locally-checked .item-text {
    color: var(--color-text-light);
  }

  #grocery-categories.hide-lunch-items .lunch-item {
    display: none;
  }

  /* Hide items already checked off in the source (grayed out) when the toggle is on */
  #grocery-categories.hide-checked-items .grocery-item.globally-checked {
    display: none;
  }

  /* Main-list item that also covers a lunch ingredient: same mint dot, normal
     text, and it NEVER hides behind the lunch toggle (dinner still needs it). */
  .grocery-item.covers-lunch .item-text::before {
    content: '';
    display: inline-block;
    width: 0.5em;
    height: 0.5em;
    margin-right: 0.5em;
    border-radius: 50%;
    background: var(--color-lunch-light);
    vertical-align: middle;
  }

  /* Lunch toggle switch */
  .lunch-toggle-label {
    font-size: 0.95rem;
    color: var(--color-lunch);
    font-weight: 600;
  }

  /* "Hide checked" toggle: neutral color + gray track so it reads as distinct
     from the mint lunch toggle sitting beside it. */
  .checked-toggle-label {
    color: var(--color-text-muted, #9a9a91);
  }

  .lunch-switch input:checked + .lunch-slider.checked-slider {
    background: var(--color-text-muted, #9a9a91);
  }

  .lunch-switch {
    position: relative;
    display: inline-block;
    width: 42px;
    height: 24px;
    flex-shrink: 0;
  }

  .lunch-switch input {
    opacity: 0;
    width: 0;
    height: 0;
  }

  .lunch-slider {
    position: absolute;
    inset: 0;
    cursor: pointer;
    background: var(--color-border);
    border-radius: 999px;
    transition: background 0.2s ease;
  }

  .lunch-slider::before {
    content: '';
    position: absolute;
    height: 18px;
    width: 18px;
    left: 3px;
    bottom: 3px;
    background: var(--color-bg);
    border-radius: 50%;
    transition: transform 0.2s ease;
  }

  .lunch-switch input:checked + .lunch-slider {
    background: var(--color-lunch);
  }

  .lunch-switch input:checked + .lunch-slider::before {
    transform: translateX(18px);
  }
</style>

