---
// LunchGroceryAddon.astro
// A separate, clearly-labeled, toggleable block appended to the main grocery
// list. Items are the deduped ingredients for mom's weekly lunches, generated
// by scripts/generate-lunch-week.mjs into src/data/lunch-week.json.
// Auto-on by default; the toggle (saved in localStorage) hides/shows it.
import lunchWeek from '../data/lunch-week.json';

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : import.meta.env.BASE_URL + '/';
const lunchHref = base + 'lunch';

const grocery = lunchWeek.grocery ?? [];
const total = grocery.reduce((n, c) => n + c.items.length, 0);
const autoGrocery = (lunchWeek as { autoGrocery?: boolean }).autoGrocery !== false;
---

{total > 0 && (
  <div class="lunch-theme mt-lg" id="lunch-grocery-addon" data-default={String(autoGrocery)}>
    <div
      id="print-section-lunch-grocery"
      class="print-section lunch-addon-box rounded-lg p-lg mb-xl w-full"
      data-section-type="lunch-grocery"
    >
      <div class="flex justify-between items-center gap-md flex-wrap mb-md">
        <div class="flex items-center gap-sm">
          <span class="lunch-chip-emoji" aria-hidden="true">🥪</span>
          <div>
            <h3 class="lunch-addon-title m-0">Lunch — added from the big list</h3>
            <p class="lunch-addon-sub m-0">For mom's week · {lunchWeek.weekTitle} · <a href={lunchHref} class="lunch-addon-link">see the plan →</a></p>
          </div>
        </div>
        <label class="lunch-switch" title="Auto-add lunch groceries">
          <input type="checkbox" id="lunch-grocery-toggle" checked={autoGrocery} />
          <span class="lunch-slider"></span>
        </label>
      </div>

      <div id="lunch-grocery-items" class="grid gap-md">
        {grocery.map((category) => (
          <div class="lunch-cat rounded-md p-md">
            <h4 class="lunch-cat-name mt-0 mb-sm">{category.name}</h4>
            <ul class="flex flex-col gap-xs">
              {category.items.map((item, index) => (
                <li class="flex items-center lunch-grocery-item">
                  <label class="flex items-center cursor-pointer w-full p-xs rounded transition-colors">
                    <input
                      type="checkbox"
                      class="lunch-checkbox"
                      data-category={category.name}
                      data-index={index}
                      data-item={item}
                    />
                    <span class="flex-1 item-text">{item}</span>
                  </label>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </div>
)}

<style>
  /* ---- cool seafoam / mint accent (distinct from the orange/yellow theme) ---- */
  .lunch-theme {
    --mint: #7cc0ae;
    --mint-deep: #3e8475;
    --mint-bg: #eaf5f1;
    --mint-bg-soft: #f1f8f5;
    --mint-border: #bfe0d6;
  }
  .lunch-addon-box {
    background: var(--mint-bg-soft);
    border: 1px solid var(--mint-border);
    border-left: 4px solid var(--mint);
  }
  .lunch-chip-emoji { font-size: 1.6rem; line-height: 1; }
  .lunch-addon-title {
    font-family: var(--font-heading);
    color: var(--color-primary);
    font-size: 1.25rem;
  }
  .lunch-addon-sub {
    color: var(--color-text-light);
    font-size: 0.9rem;
  }
  .lunch-addon-link { color: var(--mint-deep); text-decoration: none; font-weight: 600; }
  .lunch-addon-link:hover { text-decoration: underline; }
  .lunch-cat { background: var(--color-bg); border: 1px solid var(--mint-border); }
  .lunch-cat-name {
    font-family: var(--font-heading);
    color: var(--mint-deep);
    font-size: 1.05rem;
  }
  .lunch-grocery-item .item-text { font-size: 1.05rem; line-height: 1.5; }
  .lunch-grocery-item label:hover { background: var(--mint-bg); }
  .lunch-grocery-item.checked .item-text {
    text-decoration: line-through;
    color: var(--color-text-muted);
  }

  /* checkbox */
  .lunch-checkbox {
    position: relative;
    width: 1.4rem; height: 1.4rem;
    margin-right: var(--spacing-sm);
    -webkit-appearance: none; -moz-appearance: none; appearance: none;
    background: var(--color-bg);
    border: 2px solid var(--mint-border);
    border-radius: 5px;
    cursor: pointer;
    flex-shrink: 0;
  }
  .lunch-checkbox:checked { background: var(--mint); border-color: var(--mint); }
  .lunch-checkbox:checked::after {
    content: '✓';
    position: absolute; top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    color: #fff; font-size: 0.8rem; font-weight: 700;
  }

  /* toggle switch */
  .lunch-switch { position: relative; display: inline-block; width: 46px; height: 26px; flex-shrink: 0; }
  .lunch-switch input { opacity: 0; width: 0; height: 0; }
  .lunch-slider {
    position: absolute; inset: 0; cursor: pointer;
    background: var(--color-border); border-radius: 999px;
    transition: background 0.2s ease;
  }
  .lunch-slider::before {
    content: ''; position: absolute; height: 20px; width: 20px;
    left: 3px; bottom: 3px; background: #fff; border-radius: 50%;
    transition: transform 0.2s ease;
  }
  .lunch-switch input:checked + .lunch-slider { background: var(--mint); }
  .lunch-switch input:checked + .lunch-slider::before { transform: translateX(20px); }

  /* collapsed state when toggled off */
  #lunch-grocery-addon.is-off #lunch-grocery-items { display: none; }
  #lunch-grocery-addon.is-off .lunch-addon-box { opacity: 0.7; }
</style>

<script>
  (function () {
    const TOGGLE_KEY = 'lunch-grocery-enabled';
    const CHECK_KEY = 'lunch-grocery-checked';

    const addon = document.getElementById('lunch-grocery-addon');
    const toggle = document.getElementById('lunch-grocery-toggle') as HTMLInputElement | null;
    if (!addon || !toggle) return;

    // ---- show/hide toggle (default comes from the autoGrocery knob) ----
    const defaultOn = addon.dataset.default !== 'false';
    const enabled = localStorage.getItem(TOGGLE_KEY);
    const isOn = enabled === null ? defaultOn : enabled === 'true';
    toggle.checked = isOn;
    addon.classList.toggle('is-off', !isOn);
    toggle.addEventListener('change', () => {
      addon.classList.toggle('is-off', !toggle.checked);
      localStorage.setItem(TOGGLE_KEY, String(toggle.checked));
    });

    // ---- per-item checkboxes (own namespace) ----
    const load = (): Set<string> => {
      try { return new Set(JSON.parse(localStorage.getItem(CHECK_KEY) || '[]')); }
      catch { return new Set(); }
    };
    const save = (s: Set<string>) => localStorage.setItem(CHECK_KEY, JSON.stringify([...s]));
    const checked = load();

    document.querySelectorAll<HTMLInputElement>('.lunch-checkbox').forEach((box) => {
      const key = `${box.dataset.category}::${box.dataset.item}`;
      const li = box.closest('.lunch-grocery-item');
      if (checked.has(key)) { box.checked = true; li?.classList.add('checked'); }
      box.addEventListener('change', () => {
        const cur = load();
        if (box.checked) { cur.add(key); li?.classList.add('checked'); }
        else { cur.delete(key); li?.classList.remove('checked'); }
        save(cur);
      });
    });
  })();
</script>
