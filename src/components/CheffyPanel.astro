---
// CheffyPanel.astro -- the expand-on-click dialogue panel + client-side runtime.
// Full design contract: ../../CHEFFY-SYSTEM.md (Dialogue system + Features).
//
// SSR renders the current dialogue node (text, options, optional free-text input) as
// the JS-off fallback (start node only, no navigation). Data-driven from
// src/data/cheffy-dialogue.json -- no hard-coded option lists. A bundled <script>
// (below) takes over client-side traversal across the WHOLE nodes map once JS runs.
import fs from 'fs';
import path from 'path';
import dialogue from '../data/cheffy-dialogue.json';
import { parseWeekPlan } from '../utils/weekParser';

type DialogueOption = { label: string; goto?: string; action?: string };
type DialogueNode = { text: string; expression?: string; input?: boolean; options: DialogueOption[] };

const nodes = (dialogue.nodes ?? {}) as Record<string, DialogueNode>;
const startId = dialogue.start ?? 'root';
const start = nodes[startId];

// Build-time archive index -- reuses the SAME parsing source of truth as
// src/pages/archive/[slug].astro (do NOT introduce a second parser / import.meta.glob).
const archiveDir = path.join(process.cwd(), 'archive');
const files = fs.existsSync(archiveDir)
  ? fs.readdirSync(archiveDir).filter((n) => n.endsWith('.md')).sort((a, b) => b.localeCompare(a))
  : [];
const archiveIndex = await Promise.all(
  files.map(async (file) => {
    const wp = await parseWeekPlan(`archive/${file}`);
    return {
      slug: file.replace(/\.md$/, ''), // filename stem = the archive ROUTE slug, NOT slugifyWeekTitle(title)
      title: wp.weekTitle,
      meals: wp.meals.map((m) => m.title),
    };
  })
);
---

<div id="cheffy-panel" class="cheffy-panel" role="dialog" aria-label="Cheffy" hidden>
  {start ? (
    <div class="cheffy-node" data-node={startId}>
      <p class="cheffy-text">{start.text}</p>
      {start.input && (
        <input type="text" class="cheffy-input" placeholder="Search a week or meal..." aria-label="Search a week or meal" />
      )}
      <ul class="cheffy-options">
        {start.options.map((opt) => (
          <li>
            <button
              type="button"
              class="cheffy-option"
              data-goto={opt.goto ?? null}
              data-action={opt.action ?? null}
            >{opt.label}</button>
          </li>
        ))}
      </ul>
    </div>
  ) : (
    /* TODO(cheffy): populate src/data/cheffy-dialogue.json with a real tree. */
    <p class="cheffy-text">Cheffy is still warming up the kitchen.</p>
  )}
  <script type="application/json" id="cheffy-archive-index" is:inline set:html={JSON.stringify(archiveIndex)} />
</div>

<div class="cheffy-scrim" aria-hidden="true"></div>

<style>
  /* --- 2a: component-local custom props -- drive both card size and inset --- */
  .cheffy-panel {
    --cheffy-inset: clamp(1rem, 4vw, 2rem);
    /* min() caps the card at a fixed target while never exceeding the viewport
       minus its own inset on both sides -- this is what keeps the card from
       EVER reading as a fullscreen sheet, on any viewport. */
    --cheffy-card-w: min(24rem, calc(100vw - 2 * var(--cheffy-inset)));
    --cheffy-card-h: min(30rem, calc(100dvh - var(--cheffy-clear, 6rem) - var(--cheffy-inset)));
  }

  /* --- 2b: the inset floating card itself --- */
  .cheffy-panel {
    position: fixed;
    z-index: 2;
    /* non-none so the [hidden] attribute (below) has a real display value to
       toggle to/from -- required for the display+overlay discrete transition. */
    display: flex;
    flex-direction: column;
    box-sizing: border-box;
    width: var(--cheffy-card-w);
    height: auto; /* speech bubble sizes to its content */
    max-width: calc(100vw - 2 * var(--cheffy-inset));
    max-height: var(--cheffy-card-h);
    overflow-y: auto;
    padding: 1.25rem;
    gap: 0.75rem;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    box-shadow: 0 8px 30px rgba(63, 63, 55, 0.18);

    /* --- 2d: open/close animation (transform + opacity only, no layout shift) --- */
    opacity: 1;
    transform: translateY(0) scale(1);
    transition: opacity 0.22s ease, transform 0.22s ease,
                display 0.22s allow-discrete, overlay 0.22s allow-discrete;
  }

  /* --- 2c: corner anchoring -- keyed off #cheffy[data-corner], set by part 1 --- */
  /* #cheffy is owned by Cheffy.astro (different scope id), so it must be      */
  /* wrapped in :global() -- otherwise Astro's per-file scoping attribute gets */
  /* appended to a selector that the real element never carries, and the rule */
  /* silently never matches.                                                  */
  /* Bubble clears the mascot chip (~4.5rem + breathing room) so the tail can
     point at it instead of the card covering it. */
  .cheffy-panel {
    --cheffy-clear: calc(var(--cheffy-inset) + 5.4rem);
  }
  :global(#cheffy[data-corner="bottom-right"]) .cheffy-panel { right: var(--cheffy-inset); bottom: var(--cheffy-clear); }
  :global(#cheffy[data-corner="bottom-left"])  .cheffy-panel { left:  var(--cheffy-inset); bottom: var(--cheffy-clear); }
  :global(#cheffy[data-corner="top-right"])    .cheffy-panel { right: var(--cheffy-inset); top:    var(--cheffy-clear); }
  :global(#cheffy[data-corner="top-left"])     .cheffy-panel { left:  var(--cheffy-inset); top:    var(--cheffy-clear); }

  /* closed state -- owned entirely by the part-2 toggle setting panel.hidden.  */
  /* display is intentionally left unset here so the UA [hidden]{display:none}  */
  /* rule wins once the transition settles; allow-discrete keeps it painted as   */
  /* display:flex for the duration of the fade/slide out.                       */
  .cheffy-panel[hidden] {
    opacity: 0;
    transform: translateY(0.75rem) scale(0.96);
    pointer-events: none;
  }

  @starting-style {
    .cheffy-panel:not([hidden]) {
      opacity: 0;
      transform: translateY(0.75rem) scale(0.96);
    }
  }

  /* --- 2e: the scrim -- visible only while the panel is open, above page       */
  /* content but below the panel and the toggle (see :global rule below).       */
  .cheffy-scrim {
    position: fixed;
    inset: 0;
    z-index: 1;
    display: none;
    opacity: 0;
    pointer-events: none;
    background: color-mix(in srgb, var(--color-text) 22%, transparent);
    transition: opacity 0.22s ease, display 0.22s allow-discrete, overlay 0.22s allow-discrete;
  }

  #cheffy-panel:not([hidden]) ~ .cheffy-scrim {
    display: block;
    opacity: 1;
  }

  @starting-style {
    #cheffy-panel:not([hidden]) ~ .cheffy-scrim {
      opacity: 0;
    }
  }

  /* Close affordance: keep the mascot toggle (the existing close path) above
     the scrim so it stays clickable while the panel is open. Targets an
     element owned by Cheffy.astro via :global -- no edits to that file. */
  :global(#cheffy .cheffy-toggle) {
    position: relative;
    z-index: 3;
  }

  /* --- inner content: Cheffy's line, option buttons, search input ---------- */
  /* Rendered both at SSR (fallback) and by renderNode(), so style by class.   */
  .cheffy-panel :global(.cheffy-text) {
    margin: 0;
    font-family: var(--font-heading, 'Aleo', serif);
    font-size: 1.15rem;
    line-height: 1.45;
    color: var(--color-text);
    /* Dynamic nodes (e.g. archive week previews) embed literal '\n' to
       separate the title from the meal list -- render those as line breaks. */
    white-space: pre-line;
  }

  .cheffy-panel :global(.cheffy-options) {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .cheffy-panel :global(.cheffy-option) {
    display: block;
    width: 100%;
    text-align: left;
    font-family: var(--font-sans, 'Work Sans', sans-serif);
    font-size: 0.92rem;
    font-weight: 500;
    color: var(--color-text);
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 0.55rem 0.8rem;
    cursor: pointer;
    transition: background-color 0.15s ease, border-color 0.15s ease;
  }
  .cheffy-panel :global(.cheffy-option:hover) {
    background: var(--color-secondary);
    border-color: color-mix(in srgb, var(--color-secondary) 60%, var(--color-primary));
  }
  .cheffy-panel :global(.cheffy-option:focus-visible) {
    outline: 2px solid var(--color-primary);
    outline-offset: 1px;
  }
  /* last option is always the dismiss/back path -- render it quieter */
  .cheffy-panel :global(.cheffy-options li:last-child .cheffy-option) {
    background: transparent;
    border-color: transparent;
    color: var(--color-text-light);
  }
  .cheffy-panel :global(.cheffy-options li:last-child .cheffy-option:hover) {
    background: var(--color-bg-alt);
    color: var(--color-text);
  }

  .cheffy-panel :global(.cheffy-input) {
    font-family: var(--font-sans, 'Work Sans', sans-serif);
    font-size: 0.95rem;
    color: var(--color-text);
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 0.5rem 0.7rem;
    width: 100%;
    box-sizing: border-box;
  }
  .cheffy-panel :global(.cheffy-input:focus-visible) {
    outline: 2px solid var(--color-secondary);
    outline-offset: 0;
    border-color: var(--color-primary);
  }

  /* speech-bubble tail pointing at the mascot chip (bottom corners only;
     top corners just omit the tail) */
  .cheffy-panel::after {
    content: '';
    position: absolute;
    bottom: -7px;
    width: 14px;
    height: 14px;
    background: var(--color-bg);
    border-right: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    transform: rotate(45deg);
  }
  :global(#cheffy[data-corner="bottom-right"]) .cheffy-panel::after { right: 1.6rem; }
  :global(#cheffy[data-corner="bottom-left"])  .cheffy-panel::after { left: 1.6rem; }
  :global(#cheffy[data-corner="top-right"])    .cheffy-panel::after,
  :global(#cheffy[data-corner="top-left"])     .cheffy-panel::after { display: none; }

  /* Reduced-motion sweep -- scoped to this component's own elements, since       */
  /* Astro's CSS scoping does not cross component boundaries (the Cheffy.astro   */
  /* sweep only reaches #cheffy and its descendants, not this file's #cheffy-    */
  /* panel / .cheffy-scrim, which live as siblings outside that subtree).        */
  @media (prefers-reduced-motion: reduce) {
    #cheffy-panel,
    .cheffy-scrim {
      transition-duration: 0.01ms !important;
    }
  }
</style>

<script>
  // Client-side dialogue runtime. Bundled (not is:inline / define:vars) so plain ES
  // imports (JSON + the pure util) work exactly as Cheffy.astro's script imports
  // cheffyState. Scoped to an already-OPEN panel -- never touches panel.hidden or
  // aria-expanded; those stay owned by Cheffy.astro's toggle open/close (part 2).
  import dialogueTree from '../data/cheffy-dialogue.json';
  import { getNode, resolveDynamicNode, type DialogueNode, type ArchiveEntry } from '../utils/cheffyDialogue';

  type Tree = { start: string; nodes: Record<string, DialogueNode> };
  const dialogue = dialogueTree as unknown as Tree;

  // -------------------------------------------------------------------------
  // Action-dispatch registry -- the hexagonal port parts 4/5/6 plug into.
  //
  // window.cheffyActions: Record<string, (ctx: CheffyActionCtx) => void>
  // window.registerCheffyAction(name, fn): documented seam for later parts to
  // register a handler WITHOUT reworking this panel or reaching into closures.
  //
  // ctx contract (the port surface parts 4/5/6 receive):
  //   {
  //     root,            // #cheffy element
  //     panel,           // #cheffy-panel element
  //     dialogue,        // the full parsed dialogue tree
  //     nodeId,          // current node id
  //     index,           // ArchiveEntry[] build-time archive index
  //     slug?,           // present for navigate-to-archive: the matched archive slug
  //     query?,          // present for navigate-to-archive: the raw search query
  //     setState,        // root.cheffySetState -- the part-2 state-machine hook
  //     renderNode,       // (id: string) => void -- re-render the panel to another node
  //     close,           // () => void -- collapse the panel via the part-2 path
  //   }
  //
  // Unregistered actions fall through to a graceful "coming soon" default -- the
  // panel NEVER throws before parts 4/5/6 land.
  // -------------------------------------------------------------------------
  (window as any).cheffyActions = (window as any).cheffyActions || {};
  (window as any).registerCheffyAction = (name: string, fn: (ctx: any) => void) => {
    (window as any).cheffyActions = (window as any).cheffyActions || {};
    (window as any).cheffyActions[name] = fn;
  };

  function initCheffyDialogue(): void {
    const root = document.getElementById('cheffy');
    const panel = document.getElementById('cheffy-panel');
    const toggle = root?.querySelector<HTMLButtonElement>('.cheffy-toggle');
    const nodeContainer = panel?.querySelector<HTMLElement>('.cheffy-node');
    if (!root || !panel || !toggle || !nodeContainer) return; // required element missing -- PE safety, no-op
    // Idempotency guard -- same rationale as initCheffy(): never stack the
    // click listener / MutationObserver on an already-initialized panel.
    if ((panel as any).__cheffyDialogueInit) return;
    (panel as any).__cheffyDialogueInit = true;

    const startNodeId = root.dataset.startNode || dialogue.start;

    let archiveIndex: ArchiveEntry[] = [];
    const indexEl = document.getElementById('cheffy-archive-index');
    if (indexEl && indexEl.textContent) {
      try {
        archiveIndex = JSON.parse(indexEl.textContent) as ArchiveEntry[];
      } catch {
        archiveIndex = [];
      }
    }

    function buildCtx(nodeId: string, extra?: Record<string, unknown>) {
      return {
        root,
        panel,
        dialogue,
        nodeId,
        index: archiveIndex,
        setState: (root as any).cheffySetState,
        renderNode,
        close: () => {
          if (toggle && toggle.getAttribute('aria-expanded') === 'true') toggle.click();
        },
        ...extra,
      };
    }

    function dispatchAction(name: string, ctx: any): void {
      const fn = (window as any).cheffyActions?.[name];
      if (typeof fn === 'function') {
        try {
          fn(ctx);
        } catch (e) {
          console.error('[cheffy] action failed', name, e);
        }
      } else {
        defaultAction(name, ctx);
      }
    }

    function defaultAction(name: string, _ctx: any): void {
      console.info('[cheffy] no handler for', name);
      const textEl = nodeContainer!.querySelector('.cheffy-text');
      if (textEl) textEl.textContent = "That's coming soon!";
    }

    function renderNode(id: string): void {
      const node = id.startsWith('#') ? resolveDynamicNode(id, { index: archiveIndex }) : getNode(dialogue, id);
      if (!node || !nodeContainer) return;

      root.setAttribute('data-expr-override', node.expression || 'neutral');

      nodeContainer.setAttribute('data-node', id);
      nodeContainer.replaceChildren();

      const textEl = document.createElement('p');
      textEl.className = 'cheffy-text';
      textEl.textContent = node.text;
      nodeContainer.appendChild(textEl);

      if (node.input) {
        const inputEl = document.createElement('input');
        inputEl.type = 'text';
        inputEl.className = 'cheffy-input';
        inputEl.placeholder = 'Search a week or meal...';
        inputEl.setAttribute('aria-label', 'Search a week or meal');
        inputEl.addEventListener('keydown', (e) => {
          if (e.key !== 'Enter') return;
          e.preventDefault();
          renderNode('#archive-results:' + inputEl.value);
        });
        nodeContainer.appendChild(inputEl);
      }

      const list = document.createElement('ul');
      list.className = 'cheffy-options';
      for (const opt of node.options) {
        const li = document.createElement('li');
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'cheffy-option';
        if (opt.goto) btn.dataset.goto = opt.goto;
        if (opt.action) btn.dataset.action = opt.action;
        btn.textContent = opt.label;
        li.appendChild(btn);
        list.appendChild(li);
      }
      nodeContainer.appendChild(list);

      nodeContainer.setAttribute('tabindex', '-1');
      nodeContainer.focus();
    }

    // Event delegation on a STABLE parent so listeners survive renderNode() re-renders.
    panel.addEventListener('click', (e) => {
      const target = (e.target as HTMLElement)?.closest<HTMLElement>('.cheffy-option');
      if (!target || !nodeContainer.contains(target)) return;
      const goto = target.dataset.goto;
      const action = target.dataset.action;
      if (goto) {
        renderNode(goto);
      } else if (action) {
        const currentId = nodeContainer.dataset.node || startNodeId;
        // Dynamic week-preview nodes carry their slug in the node id itself
        // ('#archive-week:<slug>') -- surface it so action handlers written
        // against the ctx.slug contract (e.g. navigate-to-archive) work
        // unchanged whether the current node is static or dynamic.
        const extra = currentId.startsWith('#archive-week:') ? { slug: currentId.slice('#archive-week:'.length) } : undefined;
        dispatchAction(action, buildCtx(currentId, extra));
      }
    });

    // Part-3-owned actions: pure navigation, zero Cheffy.astro JS edits.
    (window as any).registerCheffyAction('close', () => {
      if (toggle.getAttribute('aria-expanded') === 'true') toggle.click();
    });
    (window as any).registerCheffyAction('navigate-to-archive', (ctx: any) => {
      if (!ctx.slug) return;
      // BASE_URL-aware: the site deploys under a subpath on GitHub Pages.
      const base = import.meta.env.BASE_URL.endsWith('/')
        ? import.meta.env.BASE_URL
        : import.meta.env.BASE_URL + '/';
      window.location.href = base + 'archive/' + ctx.slug;
    });
    (window as any).registerCheffyAction('navigate-to-lunch', () => {
      const base = import.meta.env.BASE_URL.endsWith('/')
        ? import.meta.env.BASE_URL
        : import.meta.env.BASE_URL + '/';
      window.location.href = base + 'lunch/';
    });

    // Open/close sync -- order-independent w.r.t. Cheffy.astro's script.
    const observer = new MutationObserver(() => {
      if (!panel.hidden) {
        renderNode(startNodeId);
      } else {
        root.removeAttribute('data-expr-override');
      }
    });
    observer.observe(panel, { attributes: true, attributeFilter: ['hidden'] });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCheffyDialogue);
  } else {
    initCheffyDialogue();
  }
</script>
