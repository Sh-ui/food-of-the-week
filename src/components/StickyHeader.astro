---
interface MealNavItem {
  id: string;
  title: string;
  cooked: boolean;
}

interface Props {
  weekTitle: string;
  shortTitle: string;
  meals: MealNavItem[];
  hasGroceryList: boolean;
}

const { weekTitle, shortTitle, meals, hasGroceryList } = Astro.props;
---

<header class="sticky-header" id="sticky-header" data-scrolled="false">
  <nav class="header-nav">
    <!-- Left: Menu label (desktop only, before scroll) / Week Title (after scroll) -->
    <div class="header-left">
      <span class="menu-label-left">Menu</span>
      <span class="header-week-title">{shortTitle}</span>
    </div>
    
    <!-- Center: Nav links (desktop) / Section selector (mobile) -->
    <div class="nav-center">
      <!-- Desktop: Nav links -->
      <div class="nav-links">
        {hasGroceryList && (
          <a href="#print-section-grocery-list" class="nav-link" data-section="grocery-list">
            Grocery
          </a>
        )}
        
        {meals.map((meal) => (
          <a 
            href={`#print-section-${meal.id}`} 
            class={`nav-link ${meal.cooked ? 'cooked' : ''}`}
            data-section={meal.id}
          >
            {meal.cooked ? '✓ ' : ''}{meal.title}
          </a>
        ))}
        
        <a href="#site-footer" class="nav-link" data-section="footer">Links</a>
      </div>
      
      <!-- Mobile: Section selector with dropdown -->
      <div class="section-selector">
        <button class="section-selector-btn" aria-expanded="false" aria-haspopup="true">
          <svg class="dropdown-caret" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="6 9 12 15 18 9"></polyline>
          </svg>
          <span class="current-section-name">Full Week</span>
          <span class="menu-label">Menu</span>
        </button>
        
        <!-- Dropdown menu -->
        <div class="section-dropdown" hidden>
          <a href="#top" class="dropdown-link">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="12" y1="19" x2="12" y2="5"></line>
              <polyline points="5 12 12 5 19 12"></polyline>
            </svg>
            Back to Top
          </a>
          
          {hasGroceryList && (
            <a href="#print-section-grocery-list" class="dropdown-link" data-section="grocery-list">
              Grocery List
            </a>
          )}
          
          {meals.map((meal) => (
            <a 
              href={`#print-section-${meal.id}`} 
              class={`dropdown-link ${meal.cooked ? 'cooked' : ''}`}
              data-section={meal.id}
            >
              {meal.cooked ? '✓ ' : ''}{meal.title}
            </a>
          ))}
          
          <a href="#site-footer" class="dropdown-link" data-section="footer">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"></circle>
              <line x1="12" y1="16" x2="12" y2="12"></line>
              <line x1="12" y1="8" x2="12.01" y2="8"></line>
            </svg>
            Links & Info
          </a>
        </div>
      </div>
    </div>
    
    <!-- Right: Print Button -->
    <button class="header-print-btn print-button" data-print-target="all" type="button">
      <svg class="print-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="6 9 6 2 18 2 18 9"></polyline>
        <path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"></path>
        <rect x="6" y="14" width="12" height="8"></rect>
      </svg>
      <span class="print-prefix">Print</span>
      <span class="print-section-name">Full Week</span>
    </button>
  </nav>
</header>

<!-- Spacer to account for fixed header -->
<div class="header-spacer"></div>

<style>
  /* Fixed Header */
  .sticky-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
    transition: box-shadow 0.3s ease;
  }

  .sticky-header[data-scrolled="true"] {
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  /* Spacer */
  .header-spacer {
    height: 56px;
  }

  /* Main Navigation Container */
  .header-nav {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--spacing-sm) var(--spacing-md);
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
    min-height: 40px;
  }

  /* Left side container */
  .header-left {
    position: absolute;
    left: var(--spacing-md);
    display: flex;
    align-items: center;
    height: 36px;
  }

  /* Menu label (desktop, before scroll) */
  .menu-label-left {
    color: var(--color-text-light);
    font-size: 0.9rem;
    font-weight: 500;
    opacity: 1;
    transition: opacity 0.3s ease;
  }

  /* Week title - hidden initially, shown on scroll */
  .header-week-title {
    position: absolute;
    left: 0;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--color-primary);
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
    cursor: pointer;
    line-height: 1;
    transform: translateY(2px);
  }

  /* When scrolled: hide menu label, show week title */
  .sticky-header[data-scrolled="true"] .menu-label-left {
    opacity: 0;
    pointer-events: none;
  }

  .sticky-header[data-scrolled="true"] .header-week-title {
    opacity: 1;
    pointer-events: auto;
  }

  /* Center area */
  .nav-center {
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.4s ease;
  }

  /* Desktop: Nav links visible, centered initially */
  .nav-links {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--spacing-xs);
  }

  /* When scrolled: shift nav links to align with left side */
  .sticky-header[data-scrolled="true"] .nav-center {
    transform: translateX(calc(-50% + var(--nav-shift-offset, 80px)));
  }

  .nav-link {
    padding: 8px 12px;
    height: 36px;
    border-radius: 4px;
    text-decoration: none;
    color: var(--color-text);
    font-size: 0.9rem;
    font-weight: 500;
    line-height: 1;
    transition: background-color 0.2s ease, color 0.2s ease;
    white-space: nowrap;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    box-sizing: border-box;
  }

  .nav-link:hover {
    background: var(--color-bg-alt);
  }

  .nav-link.active {
    background: var(--color-bg-alt);
    color: var(--color-primary);
    font-weight: 600;
  }

  .nav-link.cooked {
    color: var(--color-cooked-text);
    opacity: 0.7;
  }

  .nav-link.cooked.active {
    background: var(--color-cooked-bg);
  }

  /* Section Selector (hidden on desktop) */
  .section-selector {
    display: none;
    position: relative;
  }

  .section-selector-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 8px 12px;
    height: 36px;
    background: transparent;
    border: none;
    border-radius: 4px;
    font-family: inherit;
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-primary);
    cursor: pointer;
    transition: background-color 0.2s ease;
    line-height: 1;
  }

  .section-selector-btn:hover {
    background: var(--color-bg-alt);
  }

  .dropdown-caret {
    flex-shrink: 0;
    transition: transform 0.2s ease;
  }

  .section-selector-btn[aria-expanded="true"] .dropdown-caret {
    transform: rotate(180deg);
  }

  .current-section-name {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 200px;
    transition: opacity 0.15s ease;
  }

  /* Menu label - hidden by default, shown when dropdown open */
  .menu-label {
    display: none;
    color: var(--color-text-light);
    font-weight: 500;
  }

  .section-selector-btn[aria-expanded="true"] .current-section-name {
    display: none;
  }

  .section-selector-btn[aria-expanded="true"] .menu-label {
    display: inline;
  }

  /* Section Dropdown */
  .section-dropdown {
    position: absolute;
    top: calc(100% + 10px);
    left: 50%;
    transform: translateX(-50%);
    min-width: 280px;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.18);
    padding: 10px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    z-index: 10;
  }

  .section-dropdown[hidden] {
    display: none;
  }

  .dropdown-link {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    padding: 14px 18px;
    text-decoration: none;
    color: var(--color-text);
    font-size: 1.1rem;
    border-radius: 8px;
    transition: background-color 0.2s ease;
  }

  .dropdown-link:hover {
    background: var(--color-bg-alt);
  }

  .dropdown-link.active {
    background: var(--color-bg-alt);
    font-weight: 600;
    color: var(--color-primary);
  }

  .dropdown-link.cooked {
    color: var(--color-cooked-text);
  }

  .dropdown-link svg {
    flex-shrink: 0;
    opacity: 0.6;
  }

  /* Header Print Button - always visible, brown/primary style */
  .header-print-btn {
    position: absolute;
    right: var(--spacing-md);
    padding: 8px 14px;
    border-radius: 4px;
    font-size: 0.9rem;
    font-weight: 500;
    white-space: nowrap;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    border: none;
    background: var(--color-primary);
    color: white;
    font-family: inherit;
    line-height: 1;
    cursor: pointer;
    margin: 0;
    box-sizing: border-box;
    transition: background-color 0.2s ease, opacity 0.3s ease;
    height: 36px;
    min-width: 36px;
  }

  .header-print-btn:hover {
    background: #3a3626;
  }

  /* Desktop: Show "Print" prefix + section name, hide icon */
  .header-print-btn .print-icon {
    display: none;
    flex-shrink: 0;
  }

  .header-print-btn .print-prefix,
  .header-print-btn .print-section-name {
    display: inline;
  }

  .header-print-btn .print-prefix::after {
    content: ' ';
  }

  /* ============================================
     BREAKPOINT: 1000px - Tablet
     - Show icon + section name on print button
     ============================================ */
  @media (max-width: 1000px) {
    .header-print-btn .print-icon {
      display: inline;
    }

    .header-print-btn .print-prefix {
      display: none;
    }

    .nav-link {
      font-size: 0.85rem;
      padding: 8px 10px;
    }
  }

  /* ============================================
     BREAKPOINT: 950px - Narrow/Mobile
     - Hide nav links, show section selector
     - Print button becomes icon-only but wider
     - Hide left menu label
     ============================================ */
  @media (max-width: 950px) {
    .nav-links {
      display: none;
    }

    .section-selector {
      display: block;
    }

    .menu-label-left {
      display: none;
    }

    /* Don't shift nav on mobile */
    .sticky-header[data-scrolled="true"] .nav-center {
      transform: none;
    }

    /* Print button: icon only, beefier */
    .header-print-btn {
      padding: 8px 20px;
      min-width: 52px;
    }

    .header-print-btn .print-prefix,
    .header-print-btn .print-section-name {
      display: none;
    }

    .header-print-btn .print-icon {
      display: inline;
    }
  }

  /* ============================================
     BREAKPOINT: 500px - Small mobile
     ============================================ */
  @media (max-width: 500px) {
    .header-print-btn {
      padding: 8px 16px;
      min-width: 48px;
    }

    .current-section-name {
      max-width: 140px;
    }

    .header-week-title {
      font-size: 0.95rem;
    }

    .section-selector-btn {
      padding: 8px 10px;
    }
  }
</style>

<script>
  // Elements
  const header = document.getElementById('sticky-header') as HTMLElement;
  const sectionSelectorBtn = document.querySelector('.section-selector-btn') as HTMLButtonElement;
  const sectionDropdown = document.querySelector('.section-dropdown') as HTMLElement;
  const currentSectionName = document.querySelector('.current-section-name') as HTMLElement;
  const headerPrintBtn = document.querySelector('.header-print-btn') as HTMLButtonElement;
  const weekTitleEl = document.querySelector('.header-week-title') as HTMLElement;
  const navLinks = document.querySelectorAll('.nav-link[data-section], .dropdown-link[data-section]') as NodeListOf<HTMLAnchorElement>;
  const navCenter = document.querySelector('.nav-center') as HTMLElement;

  let currentSection = '';
  let currentPrintTarget = 'all';

  // Calculate nav shift offset based on week title width
  function updateNavShiftOffset(): void {
    if (weekTitleEl && navCenter) {
      // Measure the week title width + some padding
      const titleWidth = weekTitleEl.offsetWidth + 24;
      navCenter.style.setProperty('--nav-shift-offset', `${titleWidth}px`);
    }
  }

  // Update scroll state
  function updateScrollState(): void {
    const scrolled = window.scrollY > 100;
    header.dataset.scrolled = scrolled ? 'true' : 'false';
    
    // Update nav shift offset when scrolled
    if (scrolled) {
      updateNavShiftOffset();
    }
  }

  // Get section visibility percentage
  function getSectionVisibility(section: Element): number {
    const rect = section.getBoundingClientRect();
    const viewportHeight = window.innerHeight;
    
    if (rect.bottom < 0 || rect.top > viewportHeight) {
      return 0;
    }
    
    const visibleTop = Math.max(0, rect.top);
    const visibleBottom = Math.min(viewportHeight, rect.bottom);
    const visibleHeight = visibleBottom - visibleTop;
    
    return visibleHeight / viewportHeight;
  }

  // Update active nav link and section selector
  function updateActiveSection(): void {
    const sections = document.querySelectorAll('.print-section');
    let activeSection = '';
    let maxVisibility = 0;
    
    sections.forEach(section => {
      const visibility = getSectionVisibility(section);
      // Require 25% visibility (75% threshold means at least 25% visible at top)
      if (visibility > maxVisibility && visibility > 0.25) {
        maxVisibility = visibility;
        activeSection = section.id.replace('print-section-', '');
      }
    });

    // If no section meets threshold and we're at the top, show "Full Week"
    if (!activeSection && window.scrollY < 200) {
      updateSectionDisplay('all', 'Full Week');
      return;
    }

    if (activeSection && activeSection !== currentSection) {
      currentSection = activeSection;
      
      // Update nav links
      navLinks.forEach(link => {
        const linkSection = link.getAttribute('data-section');
        if (linkSection === activeSection) {
          link.classList.add('active');
        } else {
          link.classList.remove('active');
        }
      });

      // Get display name
      let displayName = 'Full Week';
      if (activeSection === 'grocery-list') {
        displayName = 'Grocery List';
      } else if (activeSection === 'footer') {
        displayName = 'Links & Info';
      } else if (activeSection.startsWith('meal-')) {
        const mealLink = document.querySelector(`.nav-link[data-section="${activeSection}"]`);
        if (mealLink) {
          const raw = mealLink.textContent?.trim() || 'Meal';
          displayName = raw.replace(/^[✓\u2713]\s*/, '');
        }
      }

      updateSectionDisplay(activeSection, displayName);
    }
  }

  // Update section display (selector + print button)
  function updateSectionDisplay(sectionId: string, displayName: string): void {
    // Update section selector
    if (currentSectionName) {
      currentSectionName.textContent = displayName;
    }

    // Update print button
    if (headerPrintBtn) {
      headerPrintBtn.dataset.printTarget = sectionId;
      const sectionNameEl = headerPrintBtn.querySelector('.print-section-name');
      if (sectionNameEl) {
        sectionNameEl.textContent = displayName;
      }
    }

    currentPrintTarget = sectionId;
  }

  // Section dropdown toggle
  function setupSectionDropdown(): void {
    if (!sectionSelectorBtn || !sectionDropdown) return;

    sectionSelectorBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      const isExpanded = sectionSelectorBtn.getAttribute('aria-expanded') === 'true';
      sectionSelectorBtn.setAttribute('aria-expanded', (!isExpanded).toString());
      sectionDropdown.hidden = isExpanded;
    });

    // Close on link click
    sectionDropdown.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        sectionSelectorBtn.setAttribute('aria-expanded', 'false');
        sectionDropdown.hidden = true;
      });
    });

    // Close on outside click
    document.addEventListener('click', (e) => {
      if (!sectionSelectorBtn.contains(e.target as Node) && !sectionDropdown.contains(e.target as Node)) {
        sectionSelectorBtn.setAttribute('aria-expanded', 'false');
        sectionDropdown.hidden = true;
      }
    });

    // Close on escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        sectionSelectorBtn.setAttribute('aria-expanded', 'false');
        sectionDropdown.hidden = true;
      }
    });
  }

  // Smooth scroll for nav links
  function setupSmoothScroll(): void {
    document.querySelectorAll('.nav-link, .dropdown-link').forEach(link => {
      link.addEventListener('click', (e) => {
        const href = (link as HTMLAnchorElement).getAttribute('href');
        if (href?.startsWith('#')) {
          e.preventDefault();
          const target = document.querySelector(href);
          if (target) {
            const headerHeight = header.offsetHeight;
            const targetPosition = target.getBoundingClientRect().top + window.scrollY - headerHeight - 20;
            window.scrollTo({ top: targetPosition, behavior: 'smooth' });
          }
        }
      });
    });

    // Week title click scrolls to top
    weekTitleEl?.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  }

  // Initialize
  function init(): void {
    updateScrollState();
    updateActiveSection();
    setupSectionDropdown();
    setupSmoothScroll();
    updateNavShiftOffset();

    window.addEventListener('scroll', () => {
      updateScrollState();
      updateActiveSection();
    }, { passive: true });

    window.addEventListener('resize', updateNavShiftOffset, { passive: true });
  }

  // Run on DOM ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>
