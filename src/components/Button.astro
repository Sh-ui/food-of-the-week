---
interface Props {
  /** The visual style variant */
  variant?: 'default' | 'primary' | 'secondary' | 'accent';
  /** The size preset */
  size?: 'sm' | 'md' | 'lg';
  /** Render as a link instead of button */
  href?: string;
  /** For print buttons - the target section */
  printTarget?: string;
  /** Additional CSS classes */
  class?: string;
  /** Is this a nav-style link button? */
  isNav?: boolean;
  /** Button type (for non-link buttons) */
  type?: 'button' | 'submit' | 'reset';
}

const { 
  variant = 'default',
  size = 'md',
  href,
  printTarget,
  class: className = '',
  isNav = false,
  type = 'button'
} = Astro.props;

const Tag = href ? 'a' : 'button';

const classes = [
  'btn',
  `btn-${variant}`,
  `btn-${size}`,
  isNav ? 'btn-nav' : '',
  printTarget ? 'print-button' : '',
  className
].filter(Boolean).join(' ');

const attrs = {
  class: classes,
  ...(href ? { href } : { type }),
  ...(printTarget ? { 'data-print-target': printTarget } : {})
};
---

<Tag {...attrs}>
  <slot />
</Tag>

<style is:global>
  /* Base button reset and shared styles */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--spacing-xs);
    border: none;
    border-radius: 4px;
    font-family: inherit;
    text-decoration: none;
    cursor: pointer;
    transition: background-color 0.2s ease, color 0.2s ease, opacity 0.3s ease;
    white-space: nowrap;
    margin: 0;
    box-sizing: border-box;
  }

  /* Size variants - consistent heights */
  .btn-sm {
    padding: 6px 12px;
    font-size: 0.9rem;
    font-weight: 500;
    line-height: 1.4;
    min-height: 32px;
  }

  .btn-md {
    padding: 8px 16px;
    font-size: 0.95rem;
    font-weight: 500;
    line-height: 1.4;
    min-height: 38px;
  }

  .btn-lg {
    padding: 12px 24px;
    font-size: 1.1rem;
    font-weight: 600;
    line-height: 1.4;
    min-height: 48px;
  }

  /* Color variants */
  .btn-default {
    background: transparent;
    color: var(--color-text);
  }

  .btn-default:hover {
    background: var(--color-bg-alt);
  }

  .btn-primary {
    background: var(--color-primary);
    color: white;
  }

  .btn-primary:hover {
    background: var(--color-primary-dark, #245024);
  }

  .btn-secondary {
    background: var(--color-secondary);
    color: var(--color-text);
  }

  .btn-secondary:hover {
    background: #d9b130;
  }

  .btn-accent {
    background: var(--color-accent, #e07b53);
    color: white;
  }

  .btn-accent:hover {
    background: #c96842;
  }

  /* Nav style - for header navigation buttons */
  .btn-nav {
    background: transparent;
    color: var(--color-text);
  }

  .btn-nav:hover {
    background: var(--color-bg-alt);
  }

  .btn-nav.active {
    background: var(--color-bg-alt);
    color: var(--color-primary);
    font-weight: 600;
  }

  /* Icon inside button */
  .btn svg {
    flex-shrink: 0;
    width: 1em;
    height: 1em;
  }

  /* Tablet adjustments */
  @media (max-width: 1000px) {
    .btn-sm {
      padding: 6px 10px;
      font-size: 0.85rem;
    }
  }

  /* Mobile adjustments */
  @media (max-width: 768px) {
    .btn-lg {
      padding: 10px 20px;
      font-size: 1rem;
    }
  }
</style>
