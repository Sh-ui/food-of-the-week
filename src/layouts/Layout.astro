---
interface Props {
  title: string;
  noindex?: boolean;
  /** Relative path (from project root) to this page's week Markdown source, so
   *  Cheffy's calendar-actions (ICS / Google Calendar) have real times to work
   *  from. Omit on pages with no cooking-week Markdown (lunch, fancai) -- the
   *  calendar island then stays empty and those actions cleanly no-op. */
  cheffyFilename?: string;
}

const { title, noindex = false, cheffyFilename } = Astro.props;
import '../styles/global.css';
import Cheffy from '../components/Cheffy.astro';

// Ensure proper path joining for favicon (BASE_URL may or may not have trailing slash)
const baseUrl = import.meta.env.BASE_URL.endsWith('/') 
  ? import.meta.env.BASE_URL 
  : import.meta.env.BASE_URL + '/';
const faviconHref = baseUrl + 'favicon.svg';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, shrink-to-fit=no, viewport-fit=cover" />
    <meta name="description" content="Weekly meal planning for the family" />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="icon" type="image/svg+xml" href={faviconHref} />
    <meta name="generator" content={Astro.generator} />
    <!-- Google Fonts: Work Sans (body) and Aleo (headings) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Aleo:wght@400;600;700&family=Work+Sans:wght@400;500;600&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
    <Cheffy filename={cheffyFilename} />
  </body>
</html>
